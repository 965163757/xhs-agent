# Legacy shared config. Used as fallback when split config below is empty.
OPENAI_API_KEY=sk-YOUR_OPENAI_COMPATIBLE_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional split config. Use these when text/chat and image generation need
# different gateways or API keys.
CHAT_API_KEY=
CHAT_BASE_URL=
IMAGE_API_KEY=
IMAGE_BASE_URL=

CHAT_MODEL=gpt-4o
IMAGE_MODEL=gpt-image-1
# Public app URL when deployed, e.g. https://xhs.example.com. When set,
# /static/images/... can be sent to vision/image providers as absolute URLs
# instead of being uploaded or inlined.
PUBLIC_BASE_URL=

# Production persistence: keep runtime data outside the git checkout so
# `git pull`, `git clean`, container rebuilds, or source-directory replacement
# will not erase SQLite/settings/images. start_backend.sh defaults to
# ~/.local/share/xhs-agent when this is empty.
XHS_DATA_DIR=
DATABASE_URL=sqlite+aiosqlite:///./data/xhs_agent.db
IMAGE_DIR=./data/images
PORT=8787
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
